<!DOCTYPE html>
<html>
  <head>
    <title>Simple Form</title>

    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f2f2f2;
      }

      .form-box {
        width: 400px;
        margin: 80px auto;
        padding: 30px;
        border: 2px solid #4a6fa5;
        background-color: #ffffff;
      }

      .form-group {
        margin-bottom: 20px;
      }

      label {
        display: inline-block;
        width: 80px;
        font-size: 18px;
      }

      input[type="text"],
      input[type="number"],
      input[type="file"] {
        width: 200px;
        padding: 8px;
        border: 1px solid #333;
      }

      .btn {
        margin-top: 10px;
        padding: 8px 20px;
        background-color: #4a6fa5;
        color: white;
        border: none;
        cursor: pointer;
      }

      .btn:hover {
        background-color: #3b5d8a;
      }
    </style>
  </head>
  <body>
    <div class="form-box">
      <form action="/submitform" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="name" />
        </div>

        <div class="form-group">
          <label>Age</label>
          <input type="number" name="age" />
        </div>

        <div class="form-group">
          <label>Photo</label><br />
          <input type="file"  name="userfile" />
        </div>
         <div class="form-group">
          <label>file document</label><br />
          <input type="file" multiple="multiple" name="filedocument" />
        </div>

        <button type="submit" class="btn">Submit</button>
      </form>
    </div>
  </body>
</html>
