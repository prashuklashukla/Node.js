<!DOCTYPE html>
<html>
<head>
    <title>Signup</title>
    <style>
        body{
            font-family: Arial;
            background:#f4f4f4;
        }
        .box{
            width:300px;
            margin:100px auto;
            background:white;
            padding:20px;
            border:1px solid #ccc;
        }
        input{
            width:100%;
            padding:8px;
            margin:5px 0;
        }
        button{
            width:100%;
            padding:8px;
            background:#333;
            color:white;
            border:none;
        }
        a{
            font-size:14px;
        }
    </style>
</head>
<body>

<div class="box">
    <h3>Signup</h3>

    <form action="/sigup" method="POST">

     

        <label>Email</label>
        <input type="email" name="username" >

        <label>Password</label>
        <input type="password" name="userpassword" required>

        <button type="submit">Signup</button>

    </form>

    <br>
    <a href="/login">Already have account? Login</a>

</div>

</body>
</html>
