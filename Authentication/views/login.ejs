<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <style>
        body{
            font-family: Arial;
            background:#f4f4f4;
        }
        .box{
            width:300px;
            margin:100px auto;
            background:white;
            padding:20px;
            border:1px solid #ccc;
        }
        input{
            width:100%;
            padding:8px;
            margin:5px 0;
        }
        button{
            width:100%;
            padding:8px;
            background:#333;
            color:white;
            border:none;
        }
        .error-box{
            background-color:#ffe6e6;
            color:#cc0000;
            border:1px solid #cc0000;
            padding:8px;
            margin-bottom:10px;
            font-size:14px;
        }
        .logout1 {
  background-color: #ff4d4d;
  color: white;
  border: none;
  padding: 10px 20px;
  font-size: 16px;
  font-weight: bold;
  border-radius: 5px;
  cursor: pointer;
  transition: 0.3s;
}

.logout1:hover {
  background-color: #cc0000;
}

.logout1:active {
  transform: scale(0.95);
}
    </style>
</head>
<body>
<a href="/logout">
  <button class="logout1">LOGOUT</button>
</a>
<div class="box">
    <h3>Login</h3>
 

    <form action="/login" method="POST">

        <label>Email</label>
        <input type="email" name="username" required>

        <label>Password</label>
        <input type="password" name="userpassword" required>

        <button type="submit">Login</button>

    </form>
  <!-- Error show at top -->
    <% if (typeof error !== "undefined" && error) { %>
        <div class="error-box">
            <%= error %>
        </div>
    <% } %>
</div>

</body>
</html>
