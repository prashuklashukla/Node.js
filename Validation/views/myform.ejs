<!DOCTYPE html>
<html>
  <head>
    <title>Validation Form</title>

    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
        margin: 0;
        padding: 0;
      }
  .error-box {
  background-color: #ffe6e6;
  border: 1px solid #ff4d4d;
  padding: 10px;
  margin-bottom: 15px;
  border-radius: 4px;
}

.error-box ul {
  margin: 0;
  padding-left: 20px;
}

.error-box li {
  color: #cc0000;
  font-size: 14px;
}

      form {
        width: 320px;
        margin: 60px auto;
        background: #ffffff;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 5px;
      }

      h2 {
        text-align: center;
        margin-bottom: 20px;
        color: #333;
      }

      label {
        font-size: 14px;
        font-weight: 600;
      }

      input,
      select {
        width: 100%;
        padding: 8px;
        margin: 6px 0 15px 0;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 14px;
      }

      input:focus,
      select:focus {
        outline: none;
        border-color: #555;
      }

      button {
        width: 100%;
        padding: 8px;
        background-color: #333;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
      }

      button:hover {
        background-color: #555;
      }

      
    </style>
  </head>
